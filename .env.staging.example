FLASK_ENV=staging
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql+psycopg://academic_staging:replace-with-a-strong-password@postgres:5432/academic_governance_staging
POSTGRES_USER=academic_staging
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=academic_governance_staging
AGS_HOST=0.0.0.0
AGS_PORT=5000

# SMTP example: smtp.gmail.com or smtp.sendgrid.net
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
# Example: your-email@gmail.com
EMAIL_USER=
# Example: Gmail app password or provider SMTP password
EMAIL_PASSWORD=
# Example: noreply@yourdomain.com
EMAIL_FROM=

# OAuth callback must end with /auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Sentry DSN for error tracking
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1